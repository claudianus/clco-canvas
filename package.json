    },
    "./components/streaming-text": {
      "types": "./dist/components/streaming-text.d.ts",
      "import": "./dist/components/streaming-text.js"
    },
    "./components/message-bubble": {
      "types": "./dist/components/message-bubble.d.ts",
      "import": "./dist/components/message-bubble.js"
