    "./devtools/frame-recorder": {
      "types": "./dist/devtools/frame-recorder.d.ts",
      "import": "./dist/devtools/frame-recorder.js"
    },
    "./widgets/widget": {
      "types": "./dist/widgets/widget.d.ts",
      "import": "./dist/widgets/widget.js"
    },
    "./widgets/renderer": {
      "types": "./dist/widgets/renderer.d.ts",
      "import": "./dist/widgets/renderer.js"
    },
    "./plugins/manager": {
      "types": "./dist/plugins/manager.d.ts",
      "import": "./dist/plugins/manager.js"
    },
    "./backend/xterm": {
      "types": "./dist/backend/xterm.d.ts",
      "import": "./dist/backend/xterm.js"
    },
    "./backend/websocket": {
      "types": "./dist/backend/websocket.d.ts",
      "import": "./dist/backend/websocket.js"
    }
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node ./scripts/smoke-test.mjs",
    "typecheck": "npx tsc -p tsconfig.json --noEmit"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.13"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
