    },
    "./testing/scenario": {
      "types": "./dist/testing/scenario-runner.d.ts",
      "import": "./dist/testing/scenario-runner.js"
    },
    "./accessibility/screen-reader": {
      "types": "./dist/accessibility/screen-reader.d.ts",
      "import": "./dist/accessibility/screen-reader.js"
