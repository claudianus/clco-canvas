{
  "name": "clco-canvas",
  "version": "0.7.0-alpha.0",
  "type": "module",
  "description": "A high-density TypeScript terminal UI canvas for modern CLI applications.",
  "keywords": [
    "tui",
    "terminal",
    "cli",
    "ansi",
    "cjk",
    "dashboard",
    "animation"
  ],
  "author": "claudianus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudianus/clco-canvas.git"
  },
  "homepage": "https://github.com/claudianus/clco-canvas",
  "bugs": {
    "url": "https://github.com/claudianus/clco-canvas/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./buffer": {
      "types": "./dist/buffer/cell-buffer.d.ts",
      "import": "./dist/buffer/cell-buffer.js"
    },
    "./input": {
      "types": "./dist/input/parser.d.ts",
      "import": "./dist/input/parser.js"
    },
    "./layout": {
      "types": "./dist/layout/grid.d.ts",
      "import": "./dist/layout/grid.js"
    },
    "./layout/flex": {
      "types": "./dist/layout/flex.d.ts",
      "import": "./dist/layout/flex.js"
    },
    "./layout/constraint": {
      "types": "./dist/layout/constraint.d.ts",
      "import": "./dist/layout/constraint.js"
    },
    "./layout/stack": {
      "types": "./dist/layout/stack.d.ts",
      "import": "./dist/layout/stack.js"
    },
    "./layout/grid-layout": {
      "types": "./dist/layout/grid-layout.d.ts",
      "import": "./dist/layout/grid-layout.js"
    },
    "./layout/viewport": {
      "types": "./dist/layout/viewport.d.ts",
      "import": "./dist/layout/viewport.js"
    },
    "./animation": {
      "types": "./dist/animation/easing.d.ts",
      "import": "./dist/animation/easing.js"
    },
    "./runtime/scheduler": {
      "types": "./dist/runtime/scheduler.d.ts",
      "import": "./dist/runtime/scheduler.js"
    },
    "./runtime/navigator": {
      "types": "./dist/runtime/navigator.d.ts",
      "import": "./dist/runtime/navigator.js"
    },
    "./runtime/focus": {
      "types": "./dist/runtime/focus.d.ts",
      "import": "./dist/runtime/focus.js"
    },
    "./components/button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/components/button.js"
    },
    "./components/text-input": {
      "types": "./dist/components/text-input.d.ts",
      "import": "./dist/components/text-input.js"
    },
    "./components/list": {
      "types": "./dist/components/list.d.ts",
      "import": "./dist/components/list.js"
    },
    "./components/tabs": {
      "types": "./dist/components/tabs.d.ts",
      "import": "./dist/components/tabs.js"
    },
    "./components/dialog": {
      "types": "./dist/components/dialog.d.ts",
      "import": "./dist/components/dialog.js"
    },
    "./components/spinner": {
      "types": "./dist/components/spinner.d.ts",
      "import": "./dist/components/spinner.js"
    },
    "./components/progress-bar": {
      "types": "./dist/components/progress-bar.d.ts",
