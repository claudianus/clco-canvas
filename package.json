    "./terminal": {
      "types": "./dist/terminal/index.d.ts",
      "import": "./dist/terminal/index.js"
    },
    "./text": {
      "types": "./dist/text/measure.d.ts",
      "import": "./dist/text/measure.js"
    },
    "./text/wrap": {
      "types": "./dist/text/wrap.d.ts",
      "import": "./dist/text/wrap.js"
    },
    "./testing/snapshot": {
      "types": "./dist/testing/buffer-snapshot.d.ts",
